{
  // Typecheck the Bun-run TypeScript tooling (no emit — Bun runs the .ts directly).
  // The viewer app has its own tsconfig (viewer/tsconfig.json, include: ["src"]);
  // this one covers the vault scripts, ingest pipeline, and semantic build.
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    // Deps (incl. @types/node) live in viewer/node_modules; this config sits at
    // the repo root where there is no node_modules, so point typeRoots at them.
    "typeRoots": ["./viewer/node_modules/@types"],
    "types": ["node"],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["tools/**/*.ts", "viewer/scripts/**/*.ts"]
}
