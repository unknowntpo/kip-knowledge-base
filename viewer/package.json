{
  "name": "kip-knowledge-base-viewer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "predev": "bun scripts/build-kips.ts",
    "dev": "vite",
    "prebuild": "bun scripts/build-kips.ts",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc --noEmit -p ../tsconfig.tools.json",
    "test": "vitest run",
    "embeddings": "bun ../tools/semantic/build-embeddings.ts",
    "deploy": "bun run build && bunx wrangler pages deploy",
    "cf:dev": "bun run build && bunx wrangler pages dev dist"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "@xenova/transformers": "^2.17.2",
    "gray-matter": "^4.0.3",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  }
}
